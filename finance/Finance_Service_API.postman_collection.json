              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/projects/validate/access",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "projects", "validate", "access"]
            },
            "description": "Validate access with USER role. Should return 403 Forbidden."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Budget Operations",
      "item": [
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"PROJ-001\",\n  \"plannedAmount\": 50000,\n  \"budgetCategory\": \"EQUIPMENT\",\n  \"description\": \"Equipment budget for project PROJ-001\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/budgets",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "budgets"]
            },
            "description": "Create a new budget for a project. Requires ADMIN or FINANCE_OFFICER role."
          },
          "response": []
        },
        {
          "name": "Get Budget by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{finance_officer_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/budgets/BUD-001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "budgets", "BUD-001"]
            },
            "description": "Get budget details by ID."
          },
          "response": []
        },
        {
          "name": "Get Budgets by Project",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/budgets/projects/PROJ-001?page=0&size=10&sortBy=createdAt&sortOrder=DESC",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "budgets", "projects", "PROJ-001"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "sortOrder",
                  "value": "DESC"
                }
              ]
            },
            "description": "Get all budgets for a specific project with pagination."
          },
          "response": []
        }
      ]
    }
